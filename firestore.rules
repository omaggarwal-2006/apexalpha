rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'uid', 'email']);
      
      // Portfolio subcollection
      match /portfolio/{docId} {
        allow read: if isOwner(userId);
        allow write: if false; // Must be updated ONLY via server Admin SDK
      }
    }

    // Trades collection
    match /user_trades/{tradeId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() 
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.leverage <= 200;
      allow update: if isSignedIn() 
        && resource.data.uid == request.auth.uid
        && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'exitPrice', 'pnl', 'closedAt', 'updatedAt']) || request.auth.uid == resource.data.uid);
    }

    // Bets collection
    match /bets/{betId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Ledger collection (Audit logs)
    match /ledger/{entryId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid);
      allow write: if false; // Immutable and must be appended ONLY via server Admin SDK
    }

    // Prediction Markets (Public Read)
    match /prediction_markets/{marketId} {
      allow read: if true;
      allow write: if false; // Only admin/system can write via Admin SDK/Cloud Functions
    }
  }
}
